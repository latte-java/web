{
  "variables": {
    "apiKey": "bf69486b-4733-4470-a592-f1bfce7af580",
    "asymmetricKeyId": "00000000-0000-0000-0000-000000000001",
    "keycloakJWTPopulateLambdaId": "00000000-0000-0000-0000-000000000002",
    "standardTenantId": "10000000-0000-0000-0000-000000000001",
    "standardAppId": "10000000-0000-0000-0000-000000000002",
    "rotatingRefreshAppId": "10000000-0000-0000-0000-000000000003",
    "keycloakAppId": "10000000-0000-0000-0000-000000000004",
    "standardUserId": "10000000-0000-0000-0000-000000000010",
    "standardAdminId": "10000000-0000-0000-0000-000000000011",
    "fastAppId": "20000000-0000-0000-0000-000000000002",
    "defaultPassword": "password",
    "standardAppSecret": "standard-app-secret-1234567890abcdef",
    "rotatingRefreshAppSecret": "rotating-refresh-app-secret-12345678",
    "keycloakAppSecret": "keycloak-app-secret-1234567890abcdef0",
    "fastAppSecret": "fast-app-secret-1234567890abcdef01234"
  },
  "apiKeys": [
    {
      "key": "#{apiKey}",
      "description": "Unrestricted API key for testing"
    }
  ],
  "requests": [
    {
      "method": "POST",
      "url": "/api/key/generate/#{asymmetricKeyId}",
      "body": {
        "key": {
          "algorithm": "RS256",
          "name": "For tenants",
          "length": 2048
        }
      }
    },
    {
      "method": "POST",
      "url": "/api/tenant/#{standardTenantId}",
      "body": {
        "tenant": {
          "name": "standard",
          "issuer": "http://localhost:9011/10000000-0000-0000-0000-000000000001",
          "jwtConfiguration": {
            "accessTokenKeyId": "#{asymmetricKeyId}",
            "idTokenKeyId": "#{asymmetricKeyId}",
            "refreshTokenTimeToLiveInMinutes": 43200,
            "timeToLiveInSeconds": 3600
          }
        }
      }
    },
    {
      "method": "POST",
      "url": "/api/lambda/#{keycloakJWTPopulateLambdaId}",
      "body": {
        "lambda": {
          "name": "Keycloak JWT populate",
          "type": "JWTPopulate",
          "engineType": "GraalJS",
          "body": "function populate(jwt, user, registration) {\n  jwt.realm_access = { roles: registration.roles };\n  delete jwt.roles;\n}"
        }
      }
    },
    {
      "method": "POST",
      "url": "/api/application/#{standardAppId}",
      "tenantId": "#{standardTenantId}",
      "body": {
        "application": {
          "name": "app",
          "oauthConfiguration": {
            "authorizedRedirectURLs": ["http://localhost:8080/oidc/return"],
            "clientSecret": "#{standardAppSecret}",
            "logoutURL": "http://localhost:8080/oidc/logout-return"
          },
          "roles": [
            { "name": "user" },
            { "name": "admin" },
            { "name": "moderator" }
          ]
        }
      }
    },
    {
      "method": "POST",
      "url": "/api/application/#{rotatingRefreshAppId}",
      "tenantId": "#{standardTenantId}",
      "body": {
        "application": {
          "name": "rotating-refresh-tokens",
          "jwtConfiguration": {
            "enabled": true,
            "accessTokenKeyId": "#{asymmetricKeyId}",
            "idTokenKeyId": "#{asymmetricKeyId}",
            "refreshTokenTimeToLiveInMinutes": 43200,
            "timeToLiveInSeconds": 3600,
            "refreshTokenUsagePolicy": "OneTimeUse"
          },
          "oauthConfiguration": {
            "authorizedRedirectURLs": ["http://localhost:8080/oidc/return"],
            "clientSecret": "#{rotatingRefreshAppSecret}",
            "logoutURL": "http://localhost:8080/oidc/logout-return"
          },
          "roles": [
            { "name": "user" },
            { "name": "admin" },
            { "name": "moderator" }
          ]
        }
      }
    },
    {
      "method": "POST",
      "url": "/api/application/#{keycloakAppId}",
      "tenantId": "#{standardTenantId}",
      "body": {
        "application": {
          "name": "keycloak",
          "lambdaConfiguration": {
            "accessTokenPopulateId": "#{keycloakJWTPopulateLambdaId}",
            "idTokenPopulateId": "#{keycloakJWTPopulateLambdaId}"
          },
          "oauthConfiguration": {
            "authorizedRedirectURLs": ["http://localhost:8080/oidc/return"],
            "clientSecret": "#{keycloakAppSecret}",
            "logoutURL": "http://localhost:8080/oidc/logout-return"
          },
          "roles": [
            { "name": "user" },
            { "name": "admin" },
            { "name": "moderator" }
          ]
        }
      }
    },
    {
      "method": "POST",
      "url": "/api/application/#{fastAppId}",
      "tenantId": "#{standardTenantId}",
      "body": {
        "application": {
          "name": "fast-app",
          "jwtConfiguration": {
            "enabled": true,
            "accessTokenKeyId": "#{asymmetricKeyId}",
            "idTokenKeyId": "#{asymmetricKeyId}",
            "refreshTokenTimeToLiveInMinutes": 1,
            "timeToLiveInSeconds": 1
          },
          "oauthConfiguration": {
            "authorizedRedirectURLs": ["http://localhost:8080/oidc/return"],
            "clientSecret": "#{fastAppSecret}",
            "logoutURL": "http://localhost:8080/oidc/logout-return"
          },
          "roles": [
            { "name": "user" },
            { "name": "admin" },
            { "name": "moderator" }
          ]
        }
      }
    },
    {
      "method": "POST",
      "url": "/api/user/registration/#{standardUserId}",
      "tenantId": "#{standardTenantId}",
      "body": {
        "registration": {
          "applicationId": "#{standardAppId}",
          "roles": ["user", "moderator"]
        },
        "user": {
          "email": "user@example.com",
          "password": "#{defaultPassword}"
        }
      }
    },
    {
      "method": "POST",
      "url": "/api/user/registration/#{standardAdminId}",
      "tenantId": "#{standardTenantId}",
      "body": {
        "registration": {
          "applicationId": "#{standardAppId}",
          "roles": ["admin"]
        },
        "user": {
          "email": "admin@example.com",
          "password": "#{defaultPassword}"
        }
      }
    },
    {
      "method": "POST",
      "url": "/api/user/registration/#{standardUserId}",
      "tenantId": "#{standardTenantId}",
      "body": {
        "registration": {
          "applicationId": "#{rotatingRefreshAppId}",
          "roles": ["user", "moderator"]
        }
      }
    },
    {
      "method": "POST",
      "url": "/api/user/registration/#{standardAdminId}",
      "tenantId": "#{standardTenantId}",
      "body": {
        "registration": {
          "applicationId": "#{rotatingRefreshAppId}",
          "roles": ["admin"]
        }
      }
    },
    {
      "method": "POST",
      "url": "/api/user/registration/#{standardUserId}",
      "tenantId": "#{standardTenantId}",
      "body": {
        "registration": {
          "applicationId": "#{keycloakAppId}",
          "roles": ["user", "moderator"]
        }
      }
    },
    {
      "method": "POST",
      "url": "/api/user/registration/#{standardAdminId}",
      "tenantId": "#{standardTenantId}",
      "body": {
        "registration": {
          "applicationId": "#{keycloakAppId}",
          "roles": ["admin"]
        }
      }
    },
    {
      "method": "POST",
      "url": "/api/user/registration/#{standardUserId}",
      "tenantId": "#{standardTenantId}",
      "body": {
        "registration": {
          "applicationId": "#{fastAppId}",
          "roles": ["user", "moderator"]
        }
      }
    },
    {
      "method": "POST",
      "url": "/api/user/registration/#{standardAdminId}",
      "tenantId": "#{standardTenantId}",
      "body": {
        "registration": {
          "applicationId": "#{fastAppId}",
          "roles": ["admin"]
        }
      }
    }
  ]
}
